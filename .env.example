# Copy to /etc/ubuntu-server-webui.env on the server (chmod 600), or to
# ./.env for local development.

# Port and bind address for the web UI
PORT=8443
HOST=0.0.0.0

# Admin password as a bcrypt hash. Generate with:
#   npm run hash-password -- "yourpassword"
# (You can set ADMIN_PASSWORD=plaintext instead, but the hash is preferred.)
ADMIN_PASSWORD_HASH=

# Session signing secret, at least 32 chars. Generate with:
#   openssl rand -hex 32
SESSION_SECRET=

# Root of the file browser. Everything outside is inaccessible.
FILES_ROOT=/

NODE_ENV=production
